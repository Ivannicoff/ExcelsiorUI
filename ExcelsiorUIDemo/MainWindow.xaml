<Window x:Class="ExcelsiorUIDemo.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:ExcelsiorUIDemo"
		mc:Ignorable="d"
		Title="MainWindow" Height="450" Width="800">
	<Grid Background="#FFF3F3F3">
		<StackPanel Orientation="Vertical" Margin="20">
			<TextBlock Style="{StaticResource TextBlockTitleStyle}">Excelsior UI Demo</TextBlock>
			<TextBlock Style="{StaticResource TextBlockSubtitleStyle}">Inspired by WinUI, optimized &amp; adopted for LOB</TextBlock>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition />
					<ColumnDefinition />
					<ColumnDefinition />
				</Grid.ColumnDefinitions>
				<Button Grid.Column="0" Content="Default" IsDefault="True" />
				<Button Grid.Column="1" Content="Normal" />
				<Button Grid.Column="2" Content="Escape" IsCancel="True" />
				<Button Grid.Column="3" Content="Disabled" IsEnabled="False" />
			</Grid>
		</StackPanel>
	</Grid>
</Window>